#include <iostream> // Include the iostream library for input/output operations
using namespace std; // Use the standard namespace to avoid prefixing std:: before standard library names

// Function prototype for findSameNumbers, which takes two integer arrays as parameters
void findSameNumbers(int arr1[], int arr2[]);

int main() {
   // Initialize two integer arrays with given values
    int data[] = {1, 3, 6, 7, 9}; // First array with 5 given values
    int data1[] = {5, 3, 3, 11}; // Second array with 4 given values

    for (int i = 0; i < 4; i++) { // Loop to swap the first 4 elements of the two arrays
        int temp = data[i]; 
        data[i] = data1[i];
        data1[i] = temp;
    }

    findSameNumbers(data, data1); // Call the function to find and print the same numbers in both arrays
    return 0;
}
